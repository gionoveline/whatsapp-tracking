# Opcional: URL canônica do app (produção). Use na Vercel se o OAuth redirecionar para localhost.
# Ex.: https://seu-projeto.vercel.app  (sem barra final; não use localhost em Production)
# NEXT_PUBLIC_SITE_URL=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# Meta Marketing API (leitura de campanhas/ads). Opcional se o usuário configurar no app.
META_ACCESS_TOKEN=seu-token-meta

# Google Ads API (opcional se configurar em Configurações → Google Ads API por empresa)
# GOOGLE_ADS_DEVELOPER_TOKEN=       # ou "Developer Token" na UI
# GOOGLE_OAUTH_CLIENT_ID=           # ou "ID do cliente" na UI
# GOOGLE_OAUTH_CLIENT_SECRET=       # ou "Chave secreta do cliente" na UI
# GOOGLE_ADS_CUSTOMER_ID=          # ou "ID da conta Google Ads" na UI
# GOOGLE_ADS_REFRESH_TOKEN=         # ou "Refresh Token" na UI
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=     # MCC, opcional
# SYNC_SKIP_GOOGLE_CONVERSIONS=1    # sync em massa: não enviar Lead/SQL/Venda ao Google
# SYNC_SKIP_SQL_GOOGLE=1            # legado: só SQL (ingest); implica skip SQL se GOOGLE_CONVERSIONS não setado
# Chave para criptografar valores sensíveis em app_settings (ex.: meta_access_token).
# Recomendado: 32 bytes em base64. Exemplo gerado: openssl rand -base64 32
# APP_SETTINGS_ENCRYPTION_KEY=

# OctaDesk (se for buscar dados via API; opcional para webhooks)
OCTADESK_API_TOKEN=seu-token-octadesk

# Webhook auth (token no header para validar chamadas)
WEBHOOK_SECRET=token-secreto-para-webhooks

# Cron: sync Octadesk via GET /chat (rota /api/cron/octadesk-sync). Obrigatorio em producao para o job agendado.
# Na Vercel, com CRON_SECRET definido, os Cron Jobs enviam Authorization: Bearer automaticamente.
# Plano Hobby: cron nativo max 1x/dia — use agendador HTTP externo a cada N minutos ou upgrade Pro.
# CRON_SECRET=
# Tenants processados primeiro no cron Octadesk (UUIDs separados por vírgula). Padrão: EMR.
# DESK_CRON_SYNC_PRIORITY_PARTNER_IDS=37388640-d398-46ce-8fdf-24c1875767de

