# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# Meta Marketing API (leitura de campanhas/ads). Opcional se o usuário configurar no app.
META_ACCESS_TOKEN=seu-token-meta

# OctaDesk (se for buscar dados via API; opcional para webhooks)
OCTADESK_API_TOKEN=seu-token-octadesk

# Webhook auth (token no header para validar chamadas)
WEBHOOK_SECRET=token-secreto-para-webhooks
