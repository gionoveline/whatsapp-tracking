# Opcional: URL canônica do app (produção). Use na Vercel se o OAuth redirecionar para localhost.
# Ex.: https://seu-projeto.vercel.app  (sem barra final; não use localhost em Production)
# NEXT_PUBLIC_SITE_URL=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# Meta Marketing API (leitura de campanhas/ads). Opcional se o usuário configurar no app.
META_ACCESS_TOKEN=seu-token-meta
# Chave para criptografar valores sensíveis em app_settings (ex.: meta_access_token).
# Recomendado: 32 bytes em base64. Exemplo gerado: openssl rand -base64 32
# APP_SETTINGS_ENCRYPTION_KEY=

# OctaDesk (se for buscar dados via API; opcional para webhooks)
OCTADESK_API_TOKEN=seu-token-octadesk

# Webhook auth (token no header para validar chamadas)
WEBHOOK_SECRET=token-secreto-para-webhooks
